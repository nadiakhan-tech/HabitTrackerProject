@{
	ViewData["Title"] = "Home";
}

<style>
	* {
		box-sizing: border-box;
		margin: 0;
		padding: 0;
	}

	body {
		font-family: 'Poppins', sans-serif;
		background: #f4f3fb;
		color: #1E1E2E;
	}

	/* HERO */
	.hero {
		display: flex;
		flex-direction: column;
		align-items: center;
		justify-content: center;
		text-align: center;
		padding: 5rem 2rem 3rem;
	}

	.hero-badge {
		background: #ede9ff;
		color: #534AB7;
		font-size: 12px;
		font-weight: 600;
		padding: 6px 16px;
		border-radius: 20px;
		margin-bottom: 1.5rem;
		letter-spacing: 0.5px;
	}

	.hero h1 {
		font-size: 48px;
		font-weight: 800;
		line-height: 1.15;
		max-width: 600px;
		margin-bottom: 1rem;
	}

		.hero h1 span {
			color: #534AB7;
		}

	.hero p {
		font-size: 17px;
		color: #666;
		max-width: 480px;
		line-height: 1.7;
		margin-bottom: 2rem;
	}

	.hero-buttons {
		display: flex;
		gap: 1rem;
		flex-wrap: wrap;
		justify-content: center;
	}

	.btn-primary {
		background: #534AB7;
		color: white;
		padding: 0.85rem 2rem;
		border-radius: 12px;
		font-size: 15px;
		font-weight: 600;
		text-decoration: none;
		transition: background 0.2s;
	}

		.btn-primary:hover {
			background: #3C3489;
			color: white;
		}

	.btn-outline {
		background: white;
		color: #534AB7;
		padding: 0.85rem 2rem;
		border-radius: 12px;
		font-size: 15px;
		font-weight: 600;
		text-decoration: none;
		border: 2px solid #534AB7;
		transition: all 0.2s;
	}

		.btn-outline:hover {
			background: #534AB7;
			color: white;
		}

	/* STATS BAR */
	.stats-bar {
		display: flex;
		justify-content: center;
		gap: 3rem;
		padding: 2rem;
		background: white;
		margin: 2rem auto;
		max-width: 700px;
		border-radius: 20px;
		box-shadow: 0 4px 20px rgba(83,74,183,0.08);
		flex-wrap: wrap;
	}

	.stat-item {
		text-align: center;
	}

	.stat-number {
		font-size: 28px;
		font-weight: 800;
		color: #534AB7;
	}

	.stat-label {
		font-size: 12px;
		color: #888;
		margin-top: 2px;
	}

	/* FEATURES */
	.features {
		max-width: 900px;
		margin: 1rem auto 4rem;
		padding: 0 2rem;
	}

		.features h2 {
			text-align: center;
			font-size: 28px;
			font-weight: 700;
			margin-bottom: 2rem;
		}

	.features-grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
		gap: 1.25rem;
	}

	.feature-card {
		background: white;
		border-radius: 18px;
		padding: 1.75rem;
		box-shadow: 0 4px 20px rgba(83,74,183,0.07);
		transition: transform 0.2s;
	}

		.feature-card:hover {
			transform: translateY(-4px);
		}

	.feature-emoji {
		font-size: 32px;
		margin-bottom: 1rem;
	}

	.feature-card h3 {
		font-size: 16px;
		font-weight: 700;
		margin-bottom: 0.5rem;
	}

	.feature-card p {
		font-size: 13px;
		color: #888;
		line-height: 1.6;
	}

	/* CTA */
	.cta {
		background: linear-gradient(135deg, #534AB7, #7B6FD4);
		color: white;
		text-align: center;
		padding: 4rem 2rem;
		margin: 0 2rem 4rem;
		border-radius: 24px;
		max-width: 860px;
		margin-left: auto;
		margin-right: auto;
	}

		.cta h2 {
			font-size: 30px;
			font-weight: 800;
			margin-bottom: 0.75rem;
		}

		.cta p {
			font-size: 15px;
			opacity: 0.85;
			margin-bottom: 2rem;
		}

	.btn-white {
		background: white;
		color: #534AB7;
		padding: 0.85rem 2rem;
		border-radius: 12px;
		font-size: 15px;
		font-weight: 700;
		text-decoration: none;
		transition: opacity 0.2s;
	}

		.btn-white:hover {
			opacity: 0.9;
			color: #534AB7;
		}

	@@media (max-width: 600px) {
		.hero h1 {
			font-size: 32px;
		}

		.stats-bar {
			gap: 1.5rem;
		}
	}
</style>

<!-- HERO -->
<div class="hero">
	<div class="hero-badge">🌱 Your daily habit companion</div>
	<h1>Build habits that <span>actually stick</span></h1>
	<p>Track your daily habits, build streaks, and become the best version of yourself — one day at a time.</p>
	<div class="hero-buttons">
		@if (User.Identity.IsAuthenticated)
		{
			<a href="/Habits" class="btn-primary">Go to My Habits 🔥</a>
		}
		else
		{
			<a href="/Identity/Account/Register" class="btn-primary">Get Started Free 🚀</a>
			<a href="/Identity/Account/Login" class="btn-outline">Log In</a>
		}
	</div>
</div>

<!-- STATS -->
<div class="stats-bar">
	<div class="stat-item">
		<div class="stat-number">21</div>
		<div class="stat-label">Days to build a habit</div>
	</div>
	<div class="stat-item">
		<div class="stat-number">🔥</div>
		<div class="stat-label">Track your streaks</div>
	</div>
	<div class="stat-item">
		<div class="stat-number">100%</div>
		<div class="stat-label">Free to use</div>
	</div>
</div>

<!-- FEATURES -->
<div class="features">
	<h2>Everything you need to stay consistent</h2>
	<div class="features-grid">
		<div class="feature-card">
			<div class="feature-emoji">🎯</div>
			<h3>Set Daily Goals</h3>
			<p>Define habits you want to build and track them every single day.</p>
		</div>
		<div class="feature-card">
			<div class="feature-emoji">🔥</div>
			<h3>Build Streaks</h3>
			<p>Stay consistent and watch your streaks grow longer over time.</p>
		</div>
		<div class="feature-card">
			<div class="feature-emoji">📊</div>
			<h3>Track Progress</h3>
			<p>See your journey clearly and celebrate how far you've come.</p>
		</div>
		<div class="feature-card">
			<div class="feature-emoji">🏆</div>
			<h3>Achieve More</h3>
			<p>Small daily actions lead to big long-term results.</p>
		</div>
	</div>
</div>

<!-- CTA -->
@if (!User.Identity.IsAuthenticated)
{
	<div class="cta">
		<h2>Ready to start? 🌱</h2>
		<p>Join today and take control of your daily habits. It's completely free.</p>
		<a href="/Identity/Account/Register" class="btn-white">Create Your Account</a>
	</div>
}
