@page
@model LoginModel
@{
    ViewData["Title"] = "Login";
    Layout = null;
}

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Login - HabitTracker</title>
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Poppins', sans-serif;
            background: #f0f2ff;
            min-height: 100vh;
            display: flex;
            flex-direction: column;
        }

        nav {
            background: #534AB7;
            padding: 1rem 2rem;
            display: flex;
            align-items: center;
            justify-content: space-between;
        }

            nav .logo {
                color: white;
                font-size: 20px;
                font-weight: 700;
                text-decoration: none;
            }

        .page-wrap {
            flex: 1;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 2rem;
        }

        .auth-container {
            width: 100%;
            max-width: 420px;
            background: white;
            border-radius: 20px;
            padding: 2.5rem;
            box-shadow: 0 4px 24px rgba(83,74,183,0.13);
        }

        .auth-icon {
            text-align: center;
            font-size: 42px;
            margin-bottom: 0.75rem;
        }

        .auth-title {
            font-size: 22px;
            font-weight: 700;
            color: #1E1E2E;
            margin-bottom: 0.2rem;
            text-align: center;
        }

        .auth-sub {
            font-size: 13px;
            color: #888;
            margin-bottom: 1.75rem;
            text-align: center;
        }

        .form-group {
            margin-bottom: 1rem;
        }

            .form-group label {
                font-size: 13px;
                font-weight: 600;
                color: #444;
                display: block;
                margin-bottom: 5px;
            }

            .form-group input {
                width: 100%;
                border: 1.5px solid #e0e0f0;
                border-radius: 10px;
                padding: 0.7rem 0.9rem;
                font-size: 14px;
                font-family: 'Poppins', sans-serif;
                outline: none;
                transition: border 0.2s;
            }

                .form-group input:focus {
                    border-color: #534AB7;
                }

        .checkbox-row {
            display: flex;
            align-items: center;
            gap: 8px;
            margin-bottom: 1.25rem;
            font-size: 13px;
            color: #666;
        }

        .submit-btn {
            width: 100%;
            background: #534AB7;
            color: white;
            border: none;
            border-radius: 12px;
            padding: 0.9rem;
            font-size: 15px;
            font-weight: 600;
            cursor: pointer;
            font-family: 'Poppins', sans-serif;
            margin-bottom: 1.25rem;
            transition: background 0.2s;
        }

            .submit-btn:hover {
                background: #3C3489;
            }

        .divider {
            text-align: center;
            color: #ccc;
            margin: 0.5rem 0 1rem;
            font-size: 13px;
        }

        .auth-links {
            text-align: center;
            font-size: 13px;
            color: #888;
        }

            .auth-links a {
                color: #534AB7;
                text-decoration: none;
                font-weight: 600;
            }

                .auth-links a:hover {
                    text-decoration: underline;
                }

        .error-box {
            background: #fff0f0;
            border: 1px solid #ffcccc;
            border-radius: 8px;
            padding: 0.75rem;
            font-size: 13px;
            color: #cc0000;
            margin-bottom: 1rem;
        }
    </style>
</head>
<body>
    <nav>
        <a class="logo" href="/">🌟 HabitTracker</a>
    </nav>

    <div class="page-wrap">
        <div class="auth-container">
            <div class="auth-icon">🔥</div>
            <div class="auth-title">Welcome back!</div>
            <div class="auth-sub">Log in to continue tracking your habits</div>

            <div asp-validation-summary="ModelOnly" class="error-box"></div>

            <form method="post">
                @Html.AntiForgeryToken()

                <div class="form-group">
                    <label>Email address</label>
                    <input asp-for="Input.Email" type="email" placeholder="you@example.com" autocomplete="username" />
                    <span asp-validation-for="Input.Email" style="color:red; font-size:12px;"></span>
                </div>

                <div class="form-group">
                    <label>Password</label>
                    <input asp-for="Input.Password" type="password" placeholder="Enter your password" autocomplete="current-password" />
                    <span asp-validation-for="Input.Password" style="color:red; font-size:12px;"></span>
                </div>

                <div class="checkbox-row">
                    <input asp-for="Input.RememberMe" type="checkbox" />
                    <label asp-for="Input.RememberMe">Remember me</label>
                </div>

                <button type="submit" class="submit-btn">Log in →</button>
            </form>

            <div class="divider">— or —</div>

            <div class="auth-links">
                Don't have an account? <a asp-page="./Register">Register here</a>
            </div>
        </div>
    </div>

    @section Scripts {
        <partial name="_ValidationScriptsPartial" />
    }
</body>
</html>