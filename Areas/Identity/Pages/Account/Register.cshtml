@page
@model RegisterModel
@{
	ViewData["Title"] = "Register";
}

<style>
	body {
		background: #f4f3fb;
	}

	.register-wrapper {
		display: flex;
		min-height: 90vh;
		max-width: 900px;
		margin: 2rem auto;
		border-radius: 24px;
		overflow: hidden;
		box-shadow: 0 8px 40px rgba(83,74,183,0.15);
	}

	/* LEFT PANEL */
	.register-left {
		background: linear-gradient(145deg, #534AB7, #7B6FD4);
		color: white;
		padding: 3rem 2.5rem;
		flex: 1;
		display: flex;
		flex-direction: column;
		justify-content: center;
	}

		.register-left h2 {
			font-size: 26px;
			font-weight: 700;
			margin-bottom: 0.75rem;
		}

		.register-left p {
			font-size: 14px;
			opacity: 0.85;
			margin-bottom: 2rem;
			line-height: 1.6;
		}

	.feature-item {
		display: flex;
		align-items: center;
		gap: 12px;
		margin-bottom: 1rem;
		font-size: 14px;
	}

	.feature-icon {
		background: rgba(255,255,255,0.2);
		border-radius: 10px;
		width: 38px;
		height: 38px;
		display: flex;
		align-items: center;
		justify-content: center;
		font-size: 18px;
		flex-shrink: 0;
	}

	.feature-text strong {
		display: block;
		font-weight: 600;
	}

	.feature-text span {
		opacity: 0.75;
		font-size: 12px;
	}

	/* RIGHT PANEL */
	.register-right {
		background: white;
		padding: 3rem 2.5rem;
		flex: 1;
		display: flex;
		flex-direction: column;
		justify-content: center;
	}

	.brand-icon {
		font-size: 36px;
		margin-bottom: 1rem;
	}

	.auth-title {
		font-size: 22px;
		font-weight: 700;
		color: #1E1E2E;
		margin-bottom: 0.25rem;
	}

	.auth-sub {
		font-size: 13px;
		color: #888;
		margin-bottom: 1.75rem;
	}

	.form-group {
		margin-bottom: 1rem;
	}

		.form-group label {
			font-size: 13px;
			font-weight: 600;
			color: #444;
			display: block;
			margin-bottom: 5px;
		}

		.form-group input {
			width: 100%;
			border: 1.5px solid #e0e0f0;
			border-radius: 10px;
			padding: 0.65rem 0.875rem;
			font-size: 14px;
			font-family: 'Poppins', sans-serif;
			outline: none;
			box-sizing: border-box;
		}

			.form-group input:focus {
				border-color: #534AB7;
				box-shadow: 0 0 0 3px rgba(83,74,183,0.1);
			}

	.password-hint {
		font-size: 11px;
		color: #aaa;
		margin-top: 4px;
	}

	.submit-btn {
		width: 100%;
		background: #534AB7;
		color: white;
		border: none;
		border-radius: 12px;
		padding: 0.85rem;
		font-size: 15px;
		font-weight: 600;
		cursor: pointer;
		font-family: 'Poppins', sans-serif;
		margin-top: 0.5rem;
		margin-bottom: 1rem;
		transition: background 0.2s;
	}

		.submit-btn:hover {
			background: #3C3489;
		}

	.divider {
		text-align: center;
		color: #ccc;
		font-size: 12px;
		margin: 0.5rem 0 1rem;
		position: relative;
	}

	.auth-links {
		text-align: center;
		font-size: 13px;
		color: #888;
	}

		.auth-links a {
			color: #534AB7;
			text-decoration: none;
			font-weight: 600;
		}

			.auth-links a:hover {
				text-decoration: underline;
			}

	.error-text {
		color: #e74c3c;
		font-size: 12px;
	}

	@@media (max-width: 640px) {
		.register-left {
			display: none;
		}

		.register-wrapper {
			margin: 1rem;
		}
	}
</style>

<div class="register-wrapper">

	<!-- LEFT: Benefits panel -->
	<div class="register-left">
		<h2>🌱 Build Better Habits</h2>
		<p>Join thousands of people using HabitTracker to create lasting change — one day at a time.</p>

		<div class="feature-item">
			<div class="feature-icon">🔥</div>
			<div class="feature-text">
				<strong>Build Streaks</strong>
				<span>Stay consistent and watch your streaks grow</span>
			</div>
		</div>

		<div class="feature-item">
			<div class="feature-icon">📊</div>
			<div class="feature-text">
				<strong>Track Progress</strong>
				<span>Visualise your journey with clear stats</span>
			</div>
		</div>

		<div class="feature-item">
			<div class="feature-icon">🎯</div>
			<div class="feature-text">
				<strong>Set Goals</strong>
				<span>Define daily and weekly targets</span>
			</div>
		</div>

		<div class="feature-item">
			<div class="feature-icon">🏆</div>
			<div class="feature-text">
				<strong>Celebrate Wins</strong>
				<span>Milestone rewards keep you motivated</span>
			</div>
		</div>
	</div>

	<!-- RIGHT: Form panel -->
	<div class="register-right">
		<div class="brand-icon">🌱</div>
		<div class="auth-title">Create your account</div>
		<div class="auth-sub">It's free and takes less than a minute</div>

		<form id="registerForm" asp-route-returnUrl="@Model.ReturnUrl" method="post">
			@Html.AntiForgeryToken()
			<div asp-validation-summary="ModelOnly" class="error-text" style="margin-bottom:1rem;"></div>

			<div class="form-group">
				<label>Email address</label>
				<input asp-for="Input.Email" type="email" placeholder="you@example.com" autocomplete="username" />
				<span asp-validation-for="Input.Email" class="error-text"></span>
			</div>

			<div class="form-group">
				<label>Password</label>
				<input asp-for="Input.Password" type="password" placeholder="Create a strong password" autocomplete="new-password" />
				<div class="password-hint">At least 6 characters with a number and symbol</div>
				<span asp-validation-for="Input.Password" class="error-text"></span>
			</div>

			<div class="form-group">
				<label>Confirm Password</label>
				<input asp-for="Input.ConfirmPassword" type="password" placeholder="Repeat your password" autocomplete="new-password" />
				<span asp-validation-for="Input.ConfirmPassword" class="error-text"></span>
			</div>

			<button id="registerSubmit" type="submit" class="submit-btn">
				Create Account 🚀
			</button>
		</form>

		<div class="divider">— or —</div>

		<div class="auth-links">
			Already have an account? <a asp-page="./Login">Log in here</a>
		</div>
	</div>

</div>

@section Scripts {
	<partial name="_ValidationScriptsPartial" />
}
